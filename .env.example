# hosted-aiOS — Miljövariabler
# Kopiera till .env och fyll i dina värden

# === AI API:er ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
DEEPSEEK_API_KEY=

# === Ollama (lokal LLM-server) ===
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# === Web App ===
WEBAPP_PORT=3000
WEBAPP_HOST=0.0.0.0
JWT_SECRET=generate-a-random-string-here

# === GitHub ===
GITHUB_REPO_URL=https://github.com/<user>/hosted-aios
GITHUB_TOKEN=ghp_...

# === Tailscale (om valt) ===
TAILSCALE_AUTH_KEY=tskey-...
